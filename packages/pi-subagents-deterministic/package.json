{
  "name": "@r3b1s/pi-subagents-deterministic",
  "version": "0.2.0",
  "description": "Deterministic subagent tool that resolves model and thinking from model-routing.yml, replacing pi-subagents' subagent tool via name collision.",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3b1s/pi-things.git",
    "directory": "packages/pi-subagents-deterministic"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "subagents",
    "deterministic",
    "routing"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/ test/",
    "format": "biome check --write src/ test/"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@gotgenes/pi-subagents": ">=15.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
