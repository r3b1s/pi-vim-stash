{
  "name": "@r3b1s/pi-vim-stash",
  "version": "0.2.0",
  "description": "Vim-style modal editing with prompt stash for pi's TUI editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3b1s/pi-things.git",
    "directory": "packages/pi-vim-stash"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "vim",
    "editor",
    "stash",
    "pi-coding-agent"
  ],
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome check --write ."
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "tsx": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": ">=0.47.0"
  },
  "engines": {
    "node": ">=22"
  }
}
