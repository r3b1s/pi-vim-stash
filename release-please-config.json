{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "packages/pi-subagents-deterministic": { "component": "pi-subagents-deterministic" },
    "packages/pi-holo-mem": { "component": "pi-holo-mem" },
    "packages/pi-skill-creator": { "component": "pi-skill-creator" },
    "packages/pi-token-killer": { "component": "pi-token-killer" },
    "packages/pi-vim-stash": { "component": "pi-vim-stash" }
  },
  "exclude-paths": [
    ".pi/retros",
    ".pi/skills",
    ".pi/prompts",
    "**/openspec",
    "scripts/bin",
    "toolchain-research.md",
    "**/AGENTS.md"
  ],
  "include-v-in-tag": true,
  "include-component-in-tag": true,
  "release-type": "node",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation" },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "chore", "section": "Miscellaneous Chores" },
    { "type": "refactor", "section": "Code Refactoring", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ]
}
