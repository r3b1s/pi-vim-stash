{
  "name": "@r3b1s/pi-skill-creator",
  "version": "0.2.0",
  "description": "Pi-native skill creator extension and bundled skill workflow.",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3b1s/pi-things.git",
    "directory": "packages/pi-skill-creator"
  },
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent-skills",
    "skill-creator"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension/index.ts"
  },
  "files": [
    "src",
    "skills",
    "third_party",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "package.json"
  ],
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome check --write .",
    "validate:openspec": "openspec validate add-skill-creator-extension --strict"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
