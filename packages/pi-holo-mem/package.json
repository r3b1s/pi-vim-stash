{
  "name": "@r3b1s/pi-holo-mem",
  "version": "0.2.0",
  "description": "Holographic memory for Pi — structured fact storage with compositional reasoning via HRR algebra",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3b1s/pi-things.git",
    "directory": "packages/pi-holo-mem"
  },
  "files": [
    "src",
    "python",
    "scripts",
    "README.md",
    "LICENSE",
    "plugin.yaml"
  ],
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome check --write ."
  },
  "keywords": [
    "pi",
    "extension",
    "memory",
    "holographic",
    "hrr"
  ],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=22"
  }
}
